# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/yt_audit

# Google OAuth (required for creator login)
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=

# Session secret (min 32 chars, for nuxt-auth-utils)
NUXT_SESSION_PASSWORD=

# YouTube Data API key (required for audit)
YT_API_KEY=your_youtube_api_key

# Admin password for /admin (optional, leave empty to disable admin login)
ADMIN_PASSWORD=

# Max videos to fetch from YouTube (default 140)
MAX_VIDEOS_TO_FETCH=140

# Auto-run audit and link check on creator login (default true; set to false to disable)
# AUTO_RUN_AUDIT_ON_LOGIN=true

# Audit cache TTL in hours (default 24; use 168 for weekly)
# AUDIT_CACHE_TTL_HOURS=24

# Link check result cache TTL in hours (default 24)
# LINK_CACHE_TTL_HOURS=24

# Max videos to scan for high-intent comments (default 50)
# COMMENTS_FETCH_MAX_VIDEOS=50

# API key for programmatic access (optional; if set, invalid keys are rejected)
# API_KEY=

# Rate limit: requests per minute per IP/API key (default 60)
# API_RATE_LIMIT_PER_MIN=60

# Link check concurrency and delay (default 5, 150ms)
# CHECK_LINKS_CONCURRENCY=5
# CHECK_LINKS_DELAY_MS=150

# Scheduled audit: secret for cron endpoint (optional)
# SCHEDULED_AUDIT_SECRET=

# Comma-separated channel handles for scheduled audits
# SCHEDULED_AUDIT_CHANNELS=handle1,handle2

# Webhook URL to POST audit results (Slack, Zapier, etc.)
# AUDIT_WEBHOOK_URL=

# Email notifications (Resend API) - for scheduled audit dead-link alerts
# RESEND_API_KEY=
# RESEND_FROM=YT-Audit <onboarding@resend.dev>
# NOTIFICATION_EMAIL=creator@example.com

# Optional: Hugging Face for purchase-intent detection (fallback to keywords if disabled)
# DETECT_INTENT_VIA_HF=false
# HF_TOKEN=
